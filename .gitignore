# ── Local-only documentation ──────────────────────────────────────────
Docs/

# ── Unity generated folders ────────────────────────────────────────────
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# ── Test / scenario artifacts ──────────────────────────────────────────
TestResults/
*.log
*.stacktrace

# ── Addressables / AssetStore ──────────────────────────────────────────
[Aa]ssets/AssetStoreTools*
[Aa]ssets/AddressableAssetsData/*/*.bin*

# ── Build outputs (just in case Unity puts them outside Builds/) ──────
*.apk
*.aab
*.unitypackage
*.app

# ── IDE / Editor (Visual Studio, Rider, VS Code, JetBrains) ───────────
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
.idea/
.vscode/
.vs/
*.DotSettings.user

# ── Unity crash / diagnostic ──────────────────────────────────────────
sysinfo.txt
crashlytics-build.properties

# ── OS files ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Environment / secrets (never commit credentials) ──────────────────
.env
.env.*
*.secret
secrets.json
